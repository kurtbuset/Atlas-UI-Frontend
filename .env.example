# Environment Configuration Example
# Copy this file to .env.development or .env.production and update values

# Backend Mode
# Set to "true" to use fake backend (localStorage + mock data)
# Set to "false" to use real backend API
VITE_USE_FAKE_BACKEND=true

# API Base URL (only used when VITE_USE_FAKE_BACKEND=false)
# Development: http://localhost:3000
# Production: https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:3000
